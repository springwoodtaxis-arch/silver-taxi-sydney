# Silver Service Online — Environment Configuration
# Copy this file to .env and fill in your actual values

PORT=3000

# Twilio SMS (for OTP verification)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# Email (Hostinger SMTP or any SMTP provider)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@yourdomain.com.au
SMTP_PASS=your_smtp_password_here

# Admin
ADMIN_EMAIL=info@yourdomain.com.au
ADMIN_PHONE=+61400000000
ADMIN_PASSWORD=your_admin_password_here

# Stripe Payments
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_PK=pk_live_your_stripe_publishable_key_here

# Google Maps (address autocomplete + distance)
MAPS_API_KEY=your_google_maps_api_key_here

# Telegram Bot (admin notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
